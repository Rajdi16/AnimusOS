<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <title>{{ title || 'Animus Database' }}</title>
    @vite(['resources/css/app.css', 'resources/js/app.js'])

    {{-- 🧬 SIDEBAR & LAYOUT ANIMATION STYLES --}}
    <style>
        /* Base Sidebar styling */
        .animus-sidebar {
            width: 260px;
            transition: width 0.3s cubic-bezier(0.4, 0, 0.2, 1);
            overflow-x: hidden;
            flex-shrink: 0;
            height: 100vh;
            position: sticky;
            top: 0;
            background: #161b22;
            border-right: 1px solid #30363d;
            display: flex;
            flex-direction: column;
            z-index: 100;
        }

        /* The "Small" Default State */
        .animus-sidebar.is-small {
            width: 70px;
        }

        /* Hide text elements when small */
        .animus-sidebar.is-small .nav-text,
        .animus-sidebar.is-small .sidebar-widget,
        .animus-sidebar.is-small .search-container,
        .animus-sidebar.is-small .sidebar-logo-text {
            display: none;
            opacity: 0;
        }

        /* The Logo Icon (Only shows when small) */
        .sidebar-logo-icon {
            display: none;
            font-size: 1.8rem;
            font-weight: bold;
            color: var(--assassin-red);
            text-shadow: 0 0 10px rgba(248, 81, 73, 0.5);
            text-align: center;
            width: 100%;
        }

        .animus-sidebar.is-small .sidebar-logo-icon {
            display: block;
        }

        /* Ensure links look good in both states */
        .sidebar-link {
            display: flex;
            align-items: center;
            gap: 15px;
            white-space: nowrap;
            overflow: hidden;
            color: #c9d1d9;
            text-decoration: none;
            padding: 12px 10px;
            border-radius: 6px;
            transition: background 0.2s;
        }

        .sidebar-link:hover {
            background: #21262d;
        }

        .nav-icon {
            font-size: 1.3rem;
            min-width: 30px;
            text-align: center;
        }
    </style>
</head>

