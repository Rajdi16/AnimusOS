    {{-- 🧠 THE LOGIC SCRIPTS --}}
    <script>
        document.addEventListener('DOMContentLoaded', () => {

            // 1. SIDEBAR TOGGLE LOGIC
            const toggleBtn = document.getElementById('sidebar-toggle');
            const sidebar = document.querySelector('.animus-sidebar');

            if (toggleBtn && sidebar) {
                toggleBtn.addEventListener('click', () => {
                    sidebar.classList.toggle('is-small');
                });
            }

            // 2. LIVE SEARCH LOGIC
            const searchInput = document.getElementById('animus-search');
            if (searchInput) {
                searchInput.addEventListener('keyup', (e) => {
                    const term = e.target.value.toLowerCase();
                    const cards = document.querySelectorAll('.game-poster-card');
                    cards.forEach(card => {
                        const textContent = card.innerText.toLowerCase();
                        card.style.display = textContent.includes(term) ? 'flex' : 'none';
                    });
                });
            }
        });
    </script>
</body>

</html>