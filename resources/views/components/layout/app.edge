    {{-- 🧠 THE LOGIC SCRIPTS --}}
    <script>
        document.addEventListener('DOMContentLoaded', () => {

            // 1. SIDEBAR TOGGLE LOGIC
            const toggleBtn = document.getElementById('sidebar-toggle');
            const sidebar = document.querySelector('.animus-sidebar');

            if (toggleBtn && sidebar) {
                toggleBtn.addEventListener('click', () => {
                    sidebar.classList.toggle('is-small');
                });
            }

            // 2. UNIVERSAL LIVE SEARCH PROTOCOL
            const searchInput = document.getElementById('animus-search');
            const noResults = document.getElementById('animus-no-results');
            const mainContent = document.querySelector('.content-area > *:not(#animus-no-results)');

            if (searchInput) {
                searchInput.addEventListener('input', (e) => {
                    const term = e.target.value.toLowerCase().trim();
                    const cards = document.querySelectorAll('.game-poster-card, .info-card, .forum-post-card, .character-card');
                    let matchCount = 0;

                    cards.forEach(card => {
                        const text = (card.innerText || card.textContent).toLowerCase();
                        if (text.includes(term)) {
                            card.style.display = ''; // Restore to default CSS display
                            matchCount++;
                        } else {
                            card.style.display = 'none';
                        }
                    });

                    // Handle "No Results" visibility
                    if (noResults) {
                        const isNotFound = matchCount === 0 && term.length > 0;
                        noResults.style.display = isNotFound ? 'block' : 'none';
                        
                        // Hide main content slot if nothing found to make overlay clearer
                        if (mainContent) {
                            mainContent.style.opacity = isNotFound ? '0' : '1';
                        }
                    }
                });
            }
        });
    </script>
</body>

</html>