                <p style="color: #8b949e; font-size: 0.9rem; line-height: 1.5; margin: 0;">Verify your password to access your Profile Settings.</p>
            </div>

            <form action="{{ route('profile.verify_password.post') }}" method="POST" style="display: flex; flex-direction: column; gap: 1.5rem;">
                {{ csrfField() }}

                <div>
                    <label for="password" style="display: block; color: #8b949e; font-size: 0.75rem; font-weight: 600; text-transform: uppercase; letter-spacing: 1.5px; margin-bottom: 8px;">Current Password</label>
                    <input type="password" name="password" id="password" required autofocus placeholder="••••••••••••"
                        style="width: 100%; padding: 1rem 1.2rem; background: #0d1117; border: 1px solid #30363d; border-radius: 8px; color: #e6edf3; font-size: 0.95rem; outline: none; transition: all 0.2s ease; box-sizing: border-box;"
                        onfocus="this.style.borderColor='#d29922'; this.style.boxShadow='0 0 0 3px rgba(210,153,34,0.1)'"
                        onblur="this.style.borderColor='#30363d'; this.style.boxShadow='none'">
                    @inputError('password')
                    <p style="color: #f85149; font-size: 0.8rem; margin-top: 8px; display: flex; align-items: center; gap: 5px;">⚠ {{ $messages.join(', ') }}</p>
                    @end
                </div>

                <div style="margin-top: 1rem; display: flex; flex-direction: column; gap: 1rem;">
                    <button type="submit"
                        style="width: 100%; padding: 1rem; font-weight: 700; background: #d29922; color: #000; border: none; border-radius: 8px; cursor: pointer; text-transform: uppercase; letter-spacing: 1.5px; font-size: 0.85rem; transition: all 0.2s ease;"
                        onmouseover="this.style.background='#e3a72f'; this.style.transform='translateY(-1px)'"
                        onmouseout="this.style.background='#d29922'; this.style.transform='translateY(0)'">
                        Authenticate
                    </button>
                    
                    <a href="{{ route('profile.show') }}"
                        style="text-align: center; color: #8b949e; text-decoration: none; font-size: 0.8rem; letter-spacing: 1px; padding: 0.5rem; transition: color 0.2s ease;"
                        onmouseover="this.style.color='#c9d1d9'"
                        onmouseout="this.style.color='#8b949e'">
                        Cancel Authentication
                    </a>
                </div>
            </form>
        </div>
