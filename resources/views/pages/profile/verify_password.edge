@component('components/layout/app', { title: 'Security Protocol | Abstergo OS' })

<div style="background: #0d1117; min-height: 100vh; padding: 4rem 1rem; color: #e6edf3; font-family: 'Segoe UI', Roboto, Helvetica, Arial, sans-serif; position: relative; overflow: hidden; display: flex; align-items: center; justify-content: center;">
    
    {{-- Decorative Background Elements --}}
    <div style="position: absolute; top: 50%; left: 50%; transform: translate(-50%, -50%); width: 600px; height: 600px; background: radial-gradient(circle, rgba(210,153,34,0.05) 0%, rgba(13,17,23,0) 70%); border-radius: 50%; pointer-events: none;"></div>

    <div style="max-width: 450px; width: 100%; position: relative; z-index: 10;">
        {{-- SECURITY CARD --}}
        <div style="background: rgba(22, 27, 34, 0.8); backdrop-filter: blur(10px); border: 1px solid rgba(210, 153, 34, 0.3); border-radius: 16px; padding: 3rem; box-shadow: 0 25px 50px rgba(0,0,0,0.5), 0 0 20px rgba(210, 153, 34, 0.1);">
            
            <div style="text-align: center; margin-bottom: 2.5rem;">
                <div style="display: inline-flex; align-items: center; justify-content: center; width: 60px; height: 60px; background: rgba(210, 153, 34, 0.1); border: 1px solid rgba(210, 153, 34, 0.3); border-radius: 50%; margin-bottom: 1.5rem;">
                    <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#d29922" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <rect x="3" y="11" width="18" height="11" rx="2" ry="2"></rect>
                        <path d="M7 11V7a5 5 0 0 1 10 0v4"></path>
