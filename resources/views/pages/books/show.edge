@component('components/layout/app', { title: book.title + ' | Codex Entry' })

{{-- 1. CINEMATIC HERO BANNER --}}
<div class="pages-books-show-div-109 banner-rect">
  {{-- Book Cover Background with Cloaking --}}
  <img class="pages-books-show-img-110" src="{{ book.coverImageUrl || 'https://images.hdqwalls.com/download/assassins-creed-animus-12-1920x1080.jpg' }}"
