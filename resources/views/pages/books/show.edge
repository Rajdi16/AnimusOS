      <span class="pages-books-show-span-text-112">
        Literary Fragment Identified
      </span>
      <h1 class="pages-books-show-h1-113">
        {{ book.title }}
      </h1>
    </div>
    <div class="pages-books-show-div-114">
      <p class="pages-books-show-p-text-115">AUTHOR</p>
      <p class="pages-books-show-p-text-116">
