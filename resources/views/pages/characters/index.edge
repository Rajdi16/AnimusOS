                    </h3>
                    {{-- Displays Affiliation instead of Era, colored dynamically --}}
                    <p style="margin: 8px 0 0 0; font-size: 0.7rem; color: {{ character.affiliation === 'Assassin' ? 'var(--assassin-red)' : '#64748b' }}; letter-spacing: 1.5px; text-transform: uppercase; font-weight: 600;">
                        {{ character.affiliation || 'UNKNOWN' }}
                    </p>
                </div>
            </a>

