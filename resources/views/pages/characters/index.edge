    {{-- POSTER GRID --}}
    <div class="characters-grid"
        style="display: grid; grid-template-columns: repeat(auto-fill, minmax(220px, 1fr)); gap: 1.5rem;">
        @each(character in characters)
        <div class="game-poster-card" style="
            border-radius: 12px;
            overflow: hidden;
            background: rgba(13, 17, 23, 0.8); border: 1px solid rgba(255,255,255,0.08); box-shadow: 0 10px 30px rgba(0,0,0,0.5);
            display: flex;
            flex-direction: column;
            aspect-ratio: 2 / 3; 
            position: relative;
            transition: all 0.3s ease;
        " onmouseover="this.style.transform='translateY(-5px)'; this.style.borderColor='rgba(255,255,255,0.3)'; this.style.boxShadow='0 15px 40px rgba(0,0,0,0.7), 0 0 20px rgba(0, 212, 170, 0.1)'"
           onmouseout="this.style.transform='translateY(0)'; this.style.borderColor='rgba(255,255,255,0.08)'; this.style.boxShadow='0 10px 30px rgba(0,0,0,0.5)'">
            
            {{-- Make the entire card a clickable poster --}}
            <a href="{{ route('characters.show', { id: character.id }) }}"
                style="text-decoration: none; color: inherit; display: flex; flex-direction: column; height: 100%;">

                {{-- IMAGE SECTION --}}
                <div style="flex-grow: 1; width: 100%; overflow: hidden; position: relative;">
                    <img src="{{ character.imageUrl || '/images/placeholders/animus-glitch.jpg' }}"
                        alt="{{ character.name }}" class="poster-img"
                        style="width: 100%; height: 100%; object-fit: cover; object-position: center top; transition: transform 0.5s ease;"
                        onmouseover="this.style.transform='scale(1.05)'" onmouseout="this.style.transform='scale(1)'">

                    @if(character.isPlayable)
                    <div style="position: absolute; bottom: 0; left: 0; width: 100%; padding: 1rem; background: linear-gradient(180deg, rgba(0,0,0,0) 0%, rgba(0,0,0,0.8) 100%);">
                         <span style="font-size: 0.6rem; color: #fff; font-weight: bold; letter-spacing: 2px; padding: 4px 10px; background: linear-gradient(90deg, #00d4aa 0%, #00a884 100%); border-radius: 20px; box-shadow: 0 0 10px rgba(0, 212, 170, 0.6); display: inline-flex; align-items: center; gap: 4px;">
                            <span style="display: inline-block; width: 4px; height: 4px; background: #fff; border-radius: 50%; box-shadow: 0 0 5px #fff; animation: pulse 2s infinite;"></span>
                            PLAYABLE
                        </span>
                    </div>
                    @endif
                </div>

                {{-- MINIMALIST TITLE BAR --}}
                <div style="padding: 1.2rem; text-align: center; background: rgba(255,255,255,0.02); z-index: 2; border-top: 1px solid rgba(255,255,255,0.05); position: relative;">
