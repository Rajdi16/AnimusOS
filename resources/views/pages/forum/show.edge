    {{-- 👇 NEW: ADMIN/OWNER THREAD TERMINATION BUTTON 👇 --}}
    @if(auth.user?.id === thread.userId || auth.user?.role === 'admin')
    <div class="pages-forum-show-div-absolute-188">
