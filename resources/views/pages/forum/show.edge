  {{-- 3. TRANSMISSIONS (REPLIES) --}}
  <section>
    <h3 class="pages-forum-show-h3-flex-195">
      Incoming Transmissions
      <hr class="pages-forum-show-hr-196">
      <span class="pages-auth-register-strong-text-71">({{ thread.posts.length }})</span>
    </h3>

    <div class="pages-forum-show-div-flex-197">
      @each(post in thread.posts)
      <div style="padding: 1.5rem; 
          background: {{ auth.user?.id === post.userId ? 'rgba(0, 212, 170, 0.05)' : 'rgba(0,0,0,0.3)' }}; 
          border-left: 3px solid {{ auth.user?.id === post.userId ? 'var(--assassin-red)' : '#334155' }}; 
          border-radius: 4px;">

        <div class="pages-forum-show-div-flex-198">
          <div class="pages-forum-show-div-flex-199">
            <strong class="pages-forum-show-strong-text-200">{{ post.user.username }}</strong>
            @if(auth.user?.id === post.userId)
            <span class="pages-forum-show-span-201">Owner</span>
            @endif
          </div>

          <div class="pages-forum-show-div-flex-202">
            <span class="pages-forum-show-span-text-203">
              {{ post.createdAt.toFormat('HH:mm:ss') }} // {{ post.createdAt.toFormat('dd.LL.yy') }}
            </span>

            {{-- 👇 UPDATED: SCRUB BUTTON NOW VISIBLE TO ADMINS TOO 👇 --}}
            @if(auth.user?.id === post.userId || auth.user?.role === 'admin')
            <button class="pages-forum-show-button-204" type="button" onclick="openScrubModal('{{ route('forum.destroyPost', { id: post.id }) }}')"
              
              onmouseover="this.style.background='#ef4444'; this.style.color='white'"
              onmouseout="this.style.background='none'; this.style.color='#ef4444'">
              Scrub Data {{ auth.user?.role === 'admin' && auth.user?.id !== post.userId ? '(Admin)' : '' }}
            </button>
            @endif
          </div>
        </div>

        <div class="pages-forum-show-div-text-205">
          {{ post.body }}
        </div>
      </div>
      @end
    </div>
  </section>

  {{-- 4. REPLY FORM --}}
  @if(auth.isAuthenticated)
  <div class="pages-forum-show-div-206">
    <h4 class="pages-forum-show-h4-text-207">
      Inject New Transmission
    </h4>

    <form action="{{ route('forum.reply', { id: thread.id }) }}" method="POST">
      {{ csrfField() }}
      <textarea class="pages-forum-show-textarea-208" name="body" rows="4" required placeholder="Type your message into the network..."
        
        onfocus="this.style.borderColor='var(--assassin-red)'"></textarea>

      <div class="pages-forum-show-div-flex-209">
        <button type="submit" class="pages-forum-show-button-210 btn-sync">
