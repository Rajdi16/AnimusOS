</div>

{{-- 5. STYLED SECURITY MODAL --}}
<div class="pages-forum-show-div-214" id="scrubModal">
  <div class="pages-forum-show-div-215">
    <div class="pages-forum-show-div-text-216">⚠️</div>
    <h2 class="pages-forum-show-h2-text-217">Security
      Alert</h2>
    <p class="pages-forum-show-p-text-218">Confirm permanent data purge? This action cannot be undone within
      the current simulation.</p>

    <div class="pages-forum-index-div-flex-181">
      <button class="pages-forum-show-button-219" onclick="closeScrubModal()">Abort</button>

      <form id="modalDeleteForm" action="" method="POST">
        {{ csrfField() }}
        <input type="hidden" name="_method" value="DELETE">
        <button class="pages-forum-show-button-220" type="submit">
          Confirm Scrub
        </button>
      </form>
    </div>
  </div>
</div>

{{-- 6. MODAL LOGIC --}}
<script>
  const modal = document.getElementById('scrubModal');
  const deleteForm = document.getElementById('modalDeleteForm');

  function openScrubModal(deleteUrl) {
    // 💡 FORCE THE METHOD SPOOFING IN THE URL
    // This turns /forum/1 into /forum/1?_method=DELETE
    deleteForm.action = deleteUrl + '?_method=DELETE';

    modal.style.display = 'flex';
  }

  function closeScrubModal() {
    modal.style.display = 'none';
  }

  window.onclick = function (e) {
    if (e.target == modal) closeScrubModal();
  }
</script>

@end