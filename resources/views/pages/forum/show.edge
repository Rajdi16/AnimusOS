        {{ thread.title }}
      </h1>
    </header>

    <div class="pages-forum-show-div-text-192">
      {{ thread.body }}
    </div>

    <footer class="pages-forum-show-footer-flex-193">
      <span>ESTABLISHED: {{ thread.createdAt.toFormat('dd LLL yyyy') }}</span>
      <span>STATUS: <span class="pages-forum-show-span-text-194">ENCRYPTED</span></span>
    </footer>
